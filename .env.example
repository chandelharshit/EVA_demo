# ── Gemini (LLM + Embeddings) ──────────────────────────────────────────────
# REAL: get from https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (DB + pgvector + Auth) ────────────────────────────────────────
# REAL: get from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── ElevenLabs (TTS — EVA's voice) ─────────────────────────────────────────
# REAL: get from https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 chars/month — enough for hackathon
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# EVA_VOICE_ID: "Rachel" = 21m00Tcm4TlvDq8ikWAM (warm, clear)
# Find more voices at https://elevenlabs.io/voice-library
EVA_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Google OAuth (Calendar + Login) ────────────────────────────────────────
# REAL: create at https://console.cloud.google.com → APIs & Credentials
# Enable: Google Calendar API, Google+ API
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Microsoft OAuth (Outlook Calendar) ─────────────────────────────────────
# REAL: create at https://portal.azure.com → App registrations
# Add scope: Calendars.Read
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=common

# ── App URL ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
